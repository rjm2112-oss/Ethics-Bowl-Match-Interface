{
  "name": "ethics_bowl_electron",
  "version": "1.0.0",
  "description": "Local Ethics Bowl match app",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir --publish never",
    "dist": "electron-builder --publish never",
    "dist:linux": "electron-builder --linux AppImage --publish never",
    "dist:win": "electron-builder --win nsis portable --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never"
  },
  "devDependencies": {
    "electron": "^37.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "local.ethicsbowl.match",
    "productName": "Ethics Bowl Match",
    "files": [
      "main.js",
      "debater.html",
      "debater.js",
      "instructions.html",
      "styles.css",
      "app-logo.png",
      "assets/app-icon.png",
      "ethics-bowl-logo.png",
      "assets/icon.png"
    ],
    "icon": "assets/app-icon.png",
    "linux": {
      "icon": "assets/app-icon.png",
      "target": ["AppImage"],
      "category": "Education"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.education"
    }
  }
}
